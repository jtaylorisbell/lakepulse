# Shared
LAKEPULSE_CATALOG=lakepulse
LAKEPULSE_SCHEMA=default
LAKEPULSE_LANDING_TABLE=${LAKEPULSE_CATALOG}.${LAKEPULSE_SCHEMA}.metrics_raw

# Collector (run locally on your Mac)
ZEROBUS_ENDPOINT=<workspace-id>.zerobus.<region>.cloud.databricks.com
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
DATABRICKS_CLIENT_ID=<service-principal-client-id>
DATABRICKS_CLIENT_SECRET=<service-principal-secret>
LAKEPULSE_INTERVAL=5

# Web app backend
LAKEBASE_DSN=postgresql://<user>:<pass>@<lakebase-host>:5432/<db>
