# Databricks CLI profile (used by backend, alembic, and DABs)
DATABRICKS_CONFIG_PROFILE=your-profile-name
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com

# Local dev uses a Lakebase branch to avoid touching production
# Create one with: databricks postgres create-branch ...
LAKEBASE_BRANCH_ID=dev-your-name

# Wikimedia SSE stream URL (optional, defaults to recentchange)
# WIKIMEDIA_STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange
